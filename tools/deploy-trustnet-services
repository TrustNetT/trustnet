#!/bin/bash

# TrustNet Services Website Deployment Script
# Automates: AWS login → S3 upload → CloudFront invalidation
# Usage: ./tools/deploy-trustnet-services

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
WEBSITE_DIR="$PROJECT_ROOT/trustnet-services-web"
DIST_DIR="$WEBSITE_DIR/dist"
TERRAFORM_DIR="$PROJECT_ROOT/terraform/trustnet-services"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log_info()    { echo -e "${GREEN}✓${NC} $*" >&2; }
log_warn()    { echo -e "${YELLOW}⚠${NC} $*" >&2; }
log_error()   { echo -e "${RED}✗${NC} $*" >&2; }
log_step()    { echo -e "${BLUE}→${NC} $*" >&2; }

# Display help
display_help() {
    echo "Usage: deploy-trustnet-services [options]"
    echo ""
    echo "Options:"
    echo "  --help             Show this help message"
    echo ""
    echo "Process:"
    echo "  1. Authenticate with AWS (TrustNet account, foreman user)"
    echo "  2. Validate dist/ folder exists with built files"
    echo "  3. Extract bucket name and CloudFront distribution ID from Terraform config"
    echo "  4. Upload website files to S3 bucket"
    echo "  5. Invalidate CloudFront cache"
    echo ""
    echo "Requirements:"
    echo "  - awslogin command available (for TrustNet account authentication)"
    echo "  - dist/ folder built (run: pnpm run build)"
    echo "  - Terraform state file up-to-date"
    echo ""
}

# Validate build exists
validate_build() {
    log_step "Validating build..."
    
    if [[ ! -d "$DIST_DIR" ]]; then
        log_error "Build not found at $DIST_DIR"
        log_warn "Run: cd $WEBSITE_DIR && pnpm run build"
        exit 1
    fi
    
    if [[ ! -f "$DIST_DIR/index.html" ]]; then
        log_error "Build is incomplete (missing index.html)"
        exit 1
    fi
    
    local file_count=$(find "$DIST_DIR" -type f | wc -l)
    log_info "Build validated ($file_count files)"
}

# Extract bucket name from Terraform config
get_bucket_name() {
    log_step "Extracting S3 bucket name..."
    
    if [[ ! -f "$TERRAFORM_DIR/terraform.tfvars" ]]; then
        log_error "Terraform config not found at $TERRAFORM_DIR/terraform.tfvars"
        exit 1
    fi
    
    local bucket=$(grep "services_bucket_name" "$TERRAFORM_DIR/terraform.tfvars" | grep -oP '"\K[^"]+' | head -1)
    
    if [[ -z "$bucket" ]]; then
        log_error "Could not extract bucket name from terraform.tfvars"
        exit 1
    fi
    
    echo "$bucket"
    log_info "Bucket: $bucket"
}

# Extract CloudFront distribution ID from Terraform state
get_distribution_id() {
    log_step "Extracting CloudFront distribution ID..."
    
    if [[ ! -f "$TERRAFORM_DIR/terraform.tfstate" ]]; then
        log_error "Terraform state not found at $TERRAFORM_DIR/terraform.tfstate"
        exit 1
    fi
    
    local dist_id=$(grep -oP '"id":\s*"\K[^"]+(?=.*cloudfront)' "$TERRAFORM_DIR/terraform.tfstate" | head -1)
    
    if [[ -z "$dist_id" ]]; then
        # Try alternative pattern
        dist_id=$(jq -r '.resources[] | select(.type=="aws_cloudfront_distribution") | .instances[0].attributes.id' "$TERRAFORM_DIR/terraform.tfstate" 2>/dev/null || echo "")
    fi
    
    if [[ -z "$dist_id" ]]; then
        log_error "Could not extract CloudFront distribution ID from terraform.tfstate"
        log_warn "You may need to manually run: terraform output cloudfront_distribution_id"
        exit 1
    fi
    
    echo "$dist_id"
    log_info "Distribution ID: $dist_id"
}

# Authenticate with AWS
authenticate_aws() {
    log_step "Authenticating with AWS (TrustNet account - foreman user)..."
    
    if ! command -v awslogin &> /dev/null; then
        log_error "awslogin command not found"
        log_warn "Install awslogin and configure for TrustNet account access"
        exit 1
    fi
    
    # Run awslogin to establish credentials
    if awslogin --account=TrustNet --user=foreman; then
        log_info "AWS authentication successful"
    else
        log_error "AWS authentication failed"
        exit 1
    fi
}

# Upload to S3
upload_to_s3() {
    local bucket="$1"
    
    log_step "Uploading website files to S3 bucket: $bucket..."
    
    local output
    if output=$(aws s3 sync "$DIST_DIR/" "s3://$bucket/" --delete 2>&1); then
        log_info "S3 upload complete"
        echo "$output" | grep -E "upload|delete|Completed" | head -5
    else
        log_error "S3 upload failed"
        echo "$output"
        exit 1
    fi
}

# Invalidate CloudFront
invalidate_cloudfront() {
    local dist_id="$1"
    
    log_step "Invalidating CloudFront cache (distribution: $dist_id)..."
    
    local invalidation_id=$(aws cloudfront create-invalidation \
        --distribution-id "$dist_id" \
        --paths "/*" \
        --query 'Invalidation.Id' \
        --output text)
    
    if [[ -n "$invalidation_id" ]]; then
        log_info "CloudFront invalidation created: $invalidation_id"
    else
        log_error "CloudFront invalidation failed"
        exit 1
    fi
}

# Main deployment process
deploy() {
    echo ""
    echo "╔════════════════════════════════════════════════════════════╗"
    echo "║  TrustNet Services Website - Deployment                    ║"
    echo "║  trustnet.services → S3 → CloudFront                       ║"
    echo "╚════════════════════════════════════════════════════════════╝"
    echo ""
    
    # Validate build exists
    validate_build
    echo ""
    
    # Get bucket name
    local bucket=$(get_bucket_name)
    echo ""
    
    # Get CloudFront distribution ID
    local dist_id=$(get_distribution_id)
    echo ""
    
    # Authenticate with AWS
    authenticate_aws
    echo ""
    
    # Upload to S3
    upload_to_s3 "$bucket"
    echo ""
    
    # Invalidate CloudFront
    invalidate_cloudfront "$dist_id"
    echo ""
    
    echo "╔════════════════════════════════════════════════════════════╗"
    echo "║  ✓ Deployment Complete!                                   ║"
    echo "║  Website: https://trustnet.services                        ║"
    echo "╚════════════════════════════════════════════════════════════╝"
    echo ""
}

# Main
case "${1:-}" in
    --help|-h|help)
        display_help
        ;;
    *)
        deploy
        ;;
esac
